# ============================================================
# CAPA: SERVER (ASP.NET Core)
# Copiar como .env y reemplazar los valores sintéticos con
# las credenciales reales del entorno.
# ============================================================

# --- Base de datos PostgreSQL ---
DB_HOST=<DB_HOST>
DB_PORT=<DB_PORT>
DB_NAME=<DB_NAME>
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>

# --- CORS: URL del cliente Angular (frontend) ---
URL_BACK=http://localhost:<ANGULAR_PORT>

# Configuración CORS leída por Program.cs
Cors__AllowedOrigins__0=http://localhost:<ANGULAR_PORT>
